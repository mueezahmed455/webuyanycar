# WeBuyAnyCar UK — Environment Variables
# Copy this file to .env.local for local development
# All values below are examples — replace with your real credentials

# Database
POSTGRES_URL=postgresql://user:password@host:5432/db?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/db?sslmode=require

# Authentication
JWT_SECRET_KEY=change-this-to-a-random-32-plus-character-string

# Admin
ADMIN_PASSWORD_HASH=$2b$12$examplehash...

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=quotes@webuyanycar.co.uk

# QStash (optional — for async email queueing)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=

# Vercel Blob (for file uploads)
BLOB_READ_WRITE_TOKEN=

# Rate Limiting (Redis — optional, falls back to memory)
REDIS_URL=

# Error Tracking (optional)
SENTRY_DSN=

# Google reCAPTCHA (optional)
RECAPTCHA_SECRET_KEY=

# Company info
COMPANY_NAME=WeBuyAnyCar UK
COMPANY_PHONE=0800 123 4567
COMPANY_EMAIL=quotes@webuyanycar.co.uk
COMPANY_ADDRESS=Birmingham, UK
