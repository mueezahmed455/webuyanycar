# ─── Required: Database (Vercel Postgres / Neon) ───
POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require
# Also used for migrations (non-pooled connection):
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/dbname?sslmode=require

# ─── Required: JWT / Session Secret ───
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-32-char-key-here

# ─── Required: Admin Password ───
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── Required: Vercel Blob (photo uploads) ───
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ─── Required: Email SMTP ───
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=quotes@webuyanyvehicle.co.uk

# ─── Optional: Upstash QStash (async email) ───
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=

# ─── Optional: Upstash Redis (rate limiting) ───
# REDIS_URL=redis://...

# ─── Optional: Sentry (error tracking) ───
# SENTRY_DSN=https://...@sentry.io/...

# ─── Business Details ───
COMPANY_NAME=WeBuyAnyVehicle UK
COMPANY_PHONE=0800 123 4567
COMPANY_EMAIL=quotes@webuyanyvehicle.co.uk
COMPANY_ADDRESS=Unit 12, Motor Trade Centre, 145 Industrial Road, Birmingham, B12 8LG
