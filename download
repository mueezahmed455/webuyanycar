# Required - Vercel Postgres (Neon)
POSTGRES_URL=postgresql://user:pass@host/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/dbname?sslmode=require

# Required - JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-32-char-key-here

# Required - Admin password (bcrypt hash, generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())")
ADMIN_PASSWORD_HASH=$2b$12$...

# Required - Email SMTP
